        "sites/alibaba-labelx/asr-transcription/annotation-debug-snapshot.js",
        "sites/alibaba-labelx/asr-transcription/runtime-debug.js",
        "sites/alibaba-labelx/asr-transcription/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sites/alibaba-labelx/asr-transcription/page-world/*.js",
        "sites/alibaba-labelx/asr-transcription/page-world-hook.js"
      ],
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "sites/alibaba-labelx/asr-judgement/data/thunder-question-bank.csv"
      ],
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "use_dynamic_url": true
    }
  ]
