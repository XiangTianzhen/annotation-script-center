        "sites/alibaba-labelx/asr-judgement/judgement-asr-diff-view.js",
        "sites/alibaba-labelx/asr-judgement/judgement-thunder-question.js",
        "sites/alibaba-labelx/asr-judgement/judgement-compact-card.js",
        "sites/alibaba-labelx/asr-judgement/asr-judgement-server.js",
        "sites/alibaba-labelx/asr-judgement/judgement-auto-advance.js",
        "sites/alibaba-labelx/asr-judgement/judgement-actions.js",
        "sites/alibaba-labelx/asr-judgement/judgement-toast.js",
        "sites/alibaba-labelx/asr-judgement/judgement-shortcuts.js",
        "sites/alibaba-labelx/asr-judgement/judgement-toolbar.js",
        "sites/alibaba-labelx/asr-judgement/content.js",
        "sites/alibaba-labelx/asr-transcription/document-start.js",
        "sites/alibaba-labelx/asr-transcription/site-contract.js",
        "sites/alibaba-labelx/asr-transcription/page-detector.js",
        "sites/alibaba-labelx/asr-transcription/route-observer.js",
        "sites/alibaba-labelx/asr-transcription/page-state-collector.js",
        "sites/alibaba-labelx/asr-transcription/annotation-runtime-config.js",
        "sites/alibaba-labelx/asr-transcription/runtime-gate.js",
        "sites/alibaba-labelx/asr-transcription/legacy-api-client.js",
        "sites/alibaba-labelx/asr-transcription/legacy-user-context.js",
        "sites/alibaba-labelx/asr-transcription/legacy-dictionary-sync.js",
        "sites/alibaba-labelx/asr-transcription/annotation-item-collector.js",
