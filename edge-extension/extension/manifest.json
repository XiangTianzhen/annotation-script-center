        "sites/alibaba-labelx/asr-transcription/annotation-quickfill-runner.js",
        "sites/alibaba-labelx/asr-transcription/annotation-apply-runner.js",
        "sites/alibaba-labelx/asr-transcription/annotation-apply-policy.js",
        "sites/alibaba-labelx/asr-transcription/annotation-policy-executor.js",
        "sites/alibaba-labelx/asr-transcription/annotation-page-plan-preview.js",
        "sites/alibaba-labelx/asr-transcription/annotation-page-report.js",
        "sites/alibaba-labelx/asr-transcription/annotation-page-apply-runner.js",
        "sites/alibaba-labelx/asr-transcription/legacy-save-coordinator.js",
        "sites/alibaba-labelx/asr-transcription/legacy-ai-punctuation.js",
        "sites/alibaba-labelx/asr-transcription/annotation-save-runner.js",
