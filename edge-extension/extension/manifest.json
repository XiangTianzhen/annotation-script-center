        "sites/alibaba-labelx/asr-transcription/annotation-page-flow-runner.js",
        "sites/alibaba-labelx/asr-transcription/annotation-flow-report.js",
        "sites/alibaba-labelx/asr-transcription/legacy-export.js",
        "sites/alibaba-labelx/asr-transcription/legacy-leaderboard.js",
        "sites/alibaba-labelx/asr-transcription/legacy-version-check.js",
        "sites/alibaba-labelx/asr-transcription/legacy-auto-assign.js",
        "sites/alibaba-labelx/asr-transcription/legacy-batch-flow.js",
        "sites/alibaba-labelx/asr-transcription/annotation-active-item.js",
        "sites/alibaba-labelx/asr-transcription/annotation-duration-controller.js",
        "sites/alibaba-labelx/asr-transcription/annotation-audio-controller.js",
        "sites/alibaba-labelx/asr-transcription/annotation-interaction-runner.js",
        "sites/alibaba-labelx/asr-transcription/annotation-toolbar.js",
        "sites/alibaba-labelx/asr-transcription/annotation-control-panel.js",
