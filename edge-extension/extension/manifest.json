{
  "manifest_version": 3,
  "name": "标注脚本中心",
  "description": "多平台标注脚本中心与当前页面脚本状态入口。",
  "version": "0.2.4",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://labelx.alibaba-inc.com/*",
    "https://label-cloud.lightwheel.net/*",
    "https://script.xiangtianzhen.store/*",
    "http://47.108.254.138:3101/*",
    "http://127.0.0.1:3101/*",
    "http://127.0.0.1:3333/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "标注脚本中心",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "js": [
        "sites/alibaba-labelx/asr-transcription/runtime-contract.js",
        "sites/alibaba-labelx/asr-transcription/page-world/bridge.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "js": [
        "sites/alibaba-labelx/asr-judgement/page-world/network-protocol.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-config.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-url-rewriter.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-summary.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-observer.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "sites/alibaba-labelx/asr-transcription/runtime-contract.js",
        "sites/alibaba-labelx/asr-judgement/page-detector.js",
        "sites/alibaba-labelx/asr-judgement/audio-volume-controller.js",
