# 管理员会话与下载鉴权配置（示例）
# 不要在仓库提交真实值。请复制为 config/env/backend.env 后填写真实配置。
ASC_ADMIN_PASSWORD_SHA256=your_password_sha256
ASC_ADMIN_JWT_SECRET=your_random_jwt_secret

# AI 调用日志下载可选独立凭据；留空时复用管理员凭据。
# ASC_AI_CALL_LOG_DOWNLOAD_PASSWORD_SHA256=your_password_sha256
# ASC_AI_CALL_LOG_DOWNLOAD_JWT_SECRET=your_random_jwt_secret
