# 阿里百炼 / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_BASE_URL=https://api.minimax.chat

# 其他模型服务
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=

# DataBaker AI 推荐文本
DATABAKER_AI_LISTEN_MODEL=qwen3.5-omni-flash
DATABAKER_AI_COMPARE_MODEL=qwen3.5-plus
DATABAKER_AI_TIMEOUT_MS=120000
DATABAKER_AI_MOCK=0
DATABAKER_AI_CALL_LOG_DIR=
DATABAKER_AI_ENABLE_THINKING=0
DATABAKER_AI_PIPELINE_MODE=two_stage
DATABAKER_AI_LEXICON_REWRITE_MODE=aggressive
DATABAKER_AI_CROP_EFFECTIVE_AUDIO=0
DATABAKER_AI_CROP_PADDING_SECONDS=0.12

# DataBaker 任务总表导出
DATABAKER_EXPORT_USERNAME=your_databaker_username
DATABAKER_EXPORT_PASSWORD=your_databaker_password
DATABAKER_EXPORT_LOGIN_URL=https://datafactory.data-baker.com/cms/authentication/form
DATABAKER_EXPORT_BASE_URL=https://datafactory.data-baker.com
DATABAKER_EXPORT_LANGUAGE=zh
DATABAKER_EXPORT_TOKEN_REFRESH_MS=3600000
DATABAKER_EXPORT_PAGE_SIZE=100
DATABAKER_EXPORT_DIR=
# 以下字段用于登录请求结构可配置（按 2026-04-29 实际抓包契约）
DATABAKER_EXPORT_LOGIN_METHOD=POST
DATABAKER_EXPORT_LOGIN_CREDENTIAL_IN_QUERY=1
DATABAKER_EXPORT_LOGIN_USERNAME_FIELD=username
DATABAKER_EXPORT_LOGIN_PASSWORD_FIELD=password
DATABAKER_EXPORT_LOGIN_TICKET_FIELD=ticket
DATABAKER_EXPORT_LOGIN_NOUNCE_FIELD=nounce
# 来自登录页滑块验证码通过后的参数（ticket 通常一次性，过期后需更新）
DATABAKER_EXPORT_LOGIN_TICKET=
DATABAKER_EXPORT_LOGIN_NOUNCE=
DATABAKER_EXPORT_LOGIN_QUERY_TEMPLATE_JSON={}
DATABAKER_EXPORT_LOGIN_EXTRA_BODY_JSON={}
DATABAKER_EXPORT_LOGIN_PAYLOAD_TEMPLATE_JSON=
DATABAKER_EXPORT_ACCESS_TOKEN_PATH=data.access_token
DATABAKER_EXPORT_REFRESH_TOKEN_PATH=data.refresh_token
