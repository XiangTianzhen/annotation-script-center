# 项目数据下载鉴权配置请放到 config/env/backend.env（不要写在 ai.env）

# 阿里百炼 / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Alibaba LabelX ASR 转写 AI 推荐
ASR_TRANSCRIPTION_AI_MOCK=0
ASR_TRANSCRIPTION_AI_LISTEN_MODEL=qwen3.5-omni-flash
ASR_TRANSCRIPTION_AI_COMPARE_MODEL=qwen3.5-plus
ASR_TRANSCRIPTION_AI_TIMEOUT_MS=60000
ASR_TRANSCRIPTION_AI_ENABLE_THINKING=0
ASR_TRANSCRIPTION_AI_ALLOW_CLIENT_MODEL_OVERRIDE=1

# Alibaba LabelX ASR 快判 AI 参考建议
# 说明：脚本级高级参数通过前端 aiOptions 传递，后端仅白名单接收支持字段。
ASR_JUDGEMENT_AI_MOCK=0
ASR_JUDGEMENT_AI_LISTEN_MODEL=qwen3.5-omni-flash
ASR_JUDGEMENT_AI_COMPARE_MODEL=qwen3.5-plus
ASR_JUDGEMENT_AI_TIMEOUT_MS=60000
ASR_JUDGEMENT_AI_ENABLE_THINKING=0
ASR_JUDGEMENT_AI_WEB_SEARCH_ENABLED=1
ASR_JUDGEMENT_AI_ALLOW_CLIENT_MODEL_OVERRIDE=1
# 历史兼容（compare model fallback）
ASR_JUDGEMENT_AI_MODEL=qwen3.5-plus

# DataBaker 一检质检 AI 推荐
DATABAKER_AI_MOCK=0
DATABAKER_AI_PIPELINE_MODE=two_stage
DATABAKER_AI_FUN_ASR_MODEL=fun-asr
DATABAKER_AI_FUN_ASR_PROVIDER=rest
DATABAKER_AI_FUN_ASR_PROVIDER_FALLBACK=
DATABAKER_AI_FUN_ASR_REST_BASE_URL=
DATABAKER_FUNASR_PYTHON_BIN=
DATABAKER_AI_FUN_ASR_LANGUAGE_HINTS=zh
DATABAKER_AI_FUN_ASR_POLL_INTERVAL_MS=1000
DATABAKER_AI_FUN_ASR_ASYNC_JOBS_ENABLED=1
DATABAKER_AI_JOB_TTL_MS=120000
DATABAKER_AI_JOB_MAX_SIZE=1000
DATABAKER_AI_JOB_POLL_INTERVAL_MS=1000
DATABAKER_AI_OMNI_MODEL=qwen3.5-omni-flash
DATABAKER_AI_COMPARE_MODEL=qwen3.5-plus
DATABAKER_AI_TIMEOUT_MS=60000
DATABAKER_AI_ENABLE_THINKING=0
# CONCURRENCY 控制同时处理数量；RPM_LIMIT 控制启动频率。
# Fun-ASR 不支持 thinking；thinking 只影响 Qwen Omni / compare 阶段。
# DATABAKER_FUNASR_PYTHON_BIN 仅在 DATABAKER_AI_FUN_ASR_PROVIDER=python 时使用。
DATABAKER_AI_QWEN_OMNI_RPM_LIMIT=45
DATABAKER_AI_FUN_ASR_RPM_LIMIT=500
DATABAKER_AI_TEXT_RPM_LIMIT=500
DATABAKER_AI_QWEN_OMNI_CONCURRENCY=3
DATABAKER_AI_FUN_ASR_CONCURRENCY=2
DATABAKER_AI_TEXT_CONCURRENCY=5
DATABAKER_AI_PROVIDER_RETRY_MAX=3
DATABAKER_AI_CACHE_TTL_MS=43200000
DATABAKER_AI_QUEUE_MAX_SIZE=200
DATABAKER_AI_LEXICON_REWRITE_MODE=aggressive
DATABAKER_AI_CROP_EFFECTIVE_AUDIO=0
DATABAKER_AI_CROP_PADDING_SECONDS=0.12

# Magic Data AI 质检
MAGIC_DATA_AI_MOCK=0
MAGIC_DATA_AI_LISTEN_MODEL=qwen3.5-omni-flash
MAGIC_DATA_AI_COMPARE_MODEL=qwen3.5-plus
MAGIC_DATA_AI_TIMEOUT_MS=60000
MAGIC_DATA_AI_ENABLE_THINKING=0

# Abaka AI Task21 AI 分析调试
ABAKA_TASK21_AI_MOCK=0
ABAKA_TASK21_AI_ANALYSIS_MODE=two_stage
ABAKA_TASK21_AI_VISION_MODEL=qwen3.6-plus
ABAKA_TASK21_AI_OCR_ENABLED=false
ABAKA_TASK21_AI_OCR_MODEL=
ABAKA_TASK21_AI_REASONING_MODEL=qwen3.6-plus
ABAKA_TASK21_AI_SINGLE_MODEL=qwen3.6-plus
# 兼容旧配置：未设置 ABAKA_TASK21_AI_SINGLE_MODEL 时，回退 ABAKA_TASK21_AI_MODEL
ABAKA_TASK21_AI_MODEL=qwen3.6-plus
ABAKA_TASK21_AI_ALLOWED_VISION_MODELS=qwen3.6-plus,qwen3.6-flash,qwen3-vl-plus,qwen3-vl-flash,qwen3.5-plus,qwen3.5-flash,qwen-vl-max,qwen-vl-plus
ABAKA_TASK21_AI_ALLOWED_OCR_MODELS=
ABAKA_TASK21_AI_ALLOWED_REASONING_MODELS=qwen3.6-plus,qwen3.6-flash,qwen3.5-plus,qwen3.5-flash
ABAKA_TASK21_AI_ALLOWED_SINGLE_MODELS=qwen3.6-plus,qwen3.6-flash,qwen3-vl-plus,qwen3-vl-flash,qwen3.5-plus,qwen3.5-flash,qwen-vl-max,qwen-vl-plus
ABAKA_TASK21_AI_TIMEOUT_MS=60000
ABAKA_TASK21_AI_ALLOW_CLIENT_MODEL_OVERRIDE=0
ABAKA_TASK21_AI_ENABLE_THINKING=0
ABAKA_TASK21_AI_ALLOW_THINKING_PARAM_FALLBACK=0

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_BASE_URL=https://api.minimax.chat

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
