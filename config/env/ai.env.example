# 阿里百炼 / DashScope
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id
MINIMAX_BASE_URL=https://api.minimax.chat

# 其他模型服务
SILICONFLOW_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=

# DataBaker AI 推荐文本
DATABAKER_AI_LISTEN_MODEL=qwen3.5-omni-flash
DATABAKER_AI_COMPARE_MODEL=qwen3.5-plus
DATABAKER_AI_TIMEOUT_MS=120000
DATABAKER_AI_MOCK=0
DATABAKER_AI_CALL_LOG_DIR=
DATABAKER_AI_CROP_EFFECTIVE_AUDIO=0
DATABAKER_AI_CROP_PADDING_SECONDS=0.12
