{
  "manifest_version": 3,
  "name": "标注脚本中心",
  "description": "柳州话、苏州话、金华话、台州话与杭州话标注辅助脚本中心。",
  "version": "1.1.0",
  "permissions": [
    "storage",
    "tabs",
    "cookies",
    "browsingData"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "标注脚本中心",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://cvpc.data-baker.com/*"
      ],
      "js": [
        "sites/data-baker-cvpc/liuzhou-helper/page-world/audio-observer.js"
      ],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cvpc.data-baker.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "shared/lexicon-toast.js",
        "shared/concurrent-ai-request-stream.js",
        "shared/lexicon-display.js",
        "sites/data-baker-cvpc/liuzhou-helper/editing-tab-tip-guard.js",
        "sites/data-baker-cvpc/liuzhou-helper/data-api.js",
        "sites/data-baker-cvpc/liuzhou-helper/ai-recommendation.js",
        "sites/data-baker-cvpc/liuzhou-helper/segmentation-controller.js",
        "sites/data-baker-cvpc/liuzhou-helper/ui-panel.js",
        "sites/data-baker-cvpc/liuzhou-helper/shortcuts.js",
        "sites/data-baker-cvpc/liuzhou-helper/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://work.magicdatatech.com/*"
      ],
      "js": [
        "sites/magic-data/shared/page-world/network-observer.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://work.magicdatatech.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "shared/ai-usage-meta.js",
        "shared/ai-job-client.js",
        "shared/lexicon-toast.js",
        "shared/lexicon-display.js",
        "shared/ai-cost-display.js",
        "sites/magic-data/shared/page-detector.js",
        "sites/magic-data/shared/data-collector.js",
        "sites/magic-data/hangzhou-helper/ai-review-client.js",
        "sites/magic-data/hangzhou-helper/shortcuts-runtime.js",
        "sites/magic-data/hangzhou-helper/assistant-panel.js",
        "sites/magic-data/hangzhou-helper/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://aidp.bytedance.com/*"
      ],
      "js": [
        "sites/bytedance-aidp/shared/page-world/network-observer.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://aidp.bytedance.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "shared/ai-usage-meta.js",
        "sites/bytedance-aidp/suzhou-helper/data-api.js",
        "sites/bytedance-aidp/suzhou-helper/ai-recommendation.js",
        "sites/bytedance-aidp/suzhou-helper/segmentation-controller.js",
        "sites/bytedance-aidp/suzhou-helper/ui-panel.js",
        "sites/bytedance-aidp/suzhou-helper/shortcuts.js",
        "sites/bytedance-aidp/suzhou-helper/content.js",
        "sites/bytedance-aidp/jinhua-helper/data-api.js",
        "sites/bytedance-aidp/jinhua-helper/ai-recommendation.js",
        "sites/bytedance-aidp/jinhua-helper/segmentation-controller.js",
        "sites/bytedance-aidp/jinhua-helper/ui-panel.js",
        "sites/bytedance-aidp/jinhua-helper/shortcuts.js",
        "sites/bytedance-aidp/jinhua-helper/content.js",
        "sites/bytedance-aidp/taizhou-helper/data-api.js",
        "sites/bytedance-aidp/taizhou-helper/ai-recommendation.js",
        "sites/bytedance-aidp/taizhou-helper/segmentation-controller.js",
        "sites/bytedance-aidp/taizhou-helper/ui-panel.js",
        "sites/bytedance-aidp/taizhou-helper/shortcuts.js",
        "sites/bytedance-aidp/taizhou-helper/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
