{
  "manifest_version": 3,
  "name": "标注脚本中心",
  "description": "多平台标注脚本中心与当前页面脚本状态入口。",
  "version": "0.3.0",
  "update_url": "https://script.xiangtianzhen.store/downloads/annotation-script-center-update.xml",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://labelx.alibaba-inc.com/*",
    "https://label-cloud.lightwheel.net/*",
    "https://script.xiangtianzhen.store/*",
    "https://datafactory.data-baker.com/*",
    "https://work.magicdatatech.com/*",
    "http://47.108.254.138:3101/*",
    "http://127.0.0.1:3101/*",
    "http://127.0.0.1:3333/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "action": {
    "default_title": "标注脚本中心",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://datafactory.data-baker.com/*"
      ],
      "js": [
        "sites/data-baker/round-one-quality/page-world/network-observer.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "js": [
        "sites/alibaba-labelx/asr-judgement/page-world/network-protocol.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-config.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-url-rewriter.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-summary.js",
        "sites/alibaba-labelx/asr-judgement/page-world/network-observer.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "shared/progress-indicator.js",
        "shared/statistics-supplier.js",
        "sites/alibaba-labelx/asr-judgement/page-detector.js",
        "sites/alibaba-labelx/asr-judgement/audio-volume-controller.js",
        "sites/alibaba-labelx/asr-judgement/audio-rate-controller.js",
        "sites/alibaba-labelx/asr-judgement/audio-playback-controller.js",
        "sites/alibaba-labelx/asr-judgement/audio-controller.js",
        "sites/alibaba-labelx/asr-judgement/judgement-page-size.js",
        "sites/alibaba-labelx/asr-judgement/judgement-duration-summary.js",
        "sites/alibaba-labelx/asr-judgement/judgement-virtual-window.js",
        "sites/alibaba-labelx/asr-judgement/judgement-asr-diff-view.js",
        "sites/alibaba-labelx/asr-judgement/judgement-thunder-question.js",
        "sites/alibaba-labelx/asr-judgement/judgement-compact-card.js",
        "sites/alibaba-labelx/asr-judgement/judgement-ai-suggestion.js",
        "sites/alibaba-labelx/asr-judgement/asr-judgement-server.js",
        "sites/alibaba-labelx/asr-judgement/judgement-auto-advance.js",
        "sites/alibaba-labelx/asr-judgement/judgement-actions.js",
        "sites/alibaba-labelx/asr-judgement/judgement-toast.js",
        "sites/alibaba-labelx/asr-judgement/judgement-shortcuts.js",
        "sites/alibaba-labelx/asr-judgement/judgement-toolbar.js",
        "sites/alibaba-labelx/asr-judgement/content.js",
        "sites/alibaba-labelx/asr-transcription/runtime-config.js",
        "sites/alibaba-labelx/asr-transcription/text-utils.js",
        "sites/alibaba-labelx/asr-transcription/active-item.js",
        "sites/alibaba-labelx/asr-transcription/item-actions.js",
        "sites/alibaba-labelx/asr-transcription/audio-controller.js",
        "sites/alibaba-labelx/asr-transcription/toolbar.js",
        "sites/alibaba-labelx/asr-transcription/transcription-stats-client.js",
        "sites/alibaba-labelx/asr-transcription/shortcut-bus.js",
        "sites/alibaba-labelx/asr-transcription/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://datafactory.data-baker.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "sites/data-baker/round-one-quality/data-api.js",
        "sites/data-baker/round-one-quality/ai-recommendation.js",
        "sites/data-baker/round-one-quality/ui-panel.js",
        "sites/data-baker/round-one-quality/page-size-controller.js",
        "sites/data-baker/round-one-quality/shortcuts.js",
        "sites/data-baker/round-one-quality/group-export.js",
        "sites/data-baker/round-one-quality/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://work.magicdatatech.com/*"
      ],
      "js": [
        "shared/constants.js",
        "shared/storage.js",
        "sites/magic-data/annotator/page-detector.js",
        "sites/magic-data/annotator/data-collector.js",
        "sites/magic-data/annotator/ai-review-client.js",
        "sites/magic-data/annotator/ui-panel.js",
        "sites/magic-data/annotator/content.js"
      ],
      "all_frames": false,
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sites/alibaba-labelx/asr-judgement/data/thunder-question-bank.csv"
      ],
      "matches": [
        "https://labelx.alibaba-inc.com/*"
      ],
      "use_dynamic_url": true
    }
  ]
}
